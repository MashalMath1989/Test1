rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: /users/{uid}
    // Fields:
    //   - uid: string (required) - User ID
    //   - email: string (required) - User's email
    //   - displayName: string (optional) - User's name
    //   - photoURL: string (optional) - User's photo URL
    //   - role: string (required) - 'student' or 'admin'
    //   - createdAt: timestamp (required) - Creation time
    //   - lastLogin: timestamp (required) - Last login time
    //
    // Collection: /users/{uid}/attempts/{attemptId}
    // Fields:
    //   - subjectId: string (required) - Subject name
    //   - score: number (required) - Score achieved
    //   - totalQuestions: number (required) - Total questions
    //   - markFrom40: number (required) - Mark from 40
    //   - isPassed: boolean (required) - Whether passed
    //   - timestamp: timestamp (required) - Quiz time
    //
    // Collection: /users/{uid}/progress/current
    // Fields:
    //   - lastSubject: string (optional) - Last subject studied
    //   - totalQuizzes: number (optional) - Total quizzes taken
    //   - totalScore: number (optional) - Total score achieved
    //   - lastUpdated: timestamp (required) - Last update time
    //
    // Collection: /users/{uid}/quizProgress/{examTitle}
    // Fields:
    //   - subjectId: string (required)
    //   - examTitle: string (required)
    //   - currentQuestionIndex: number (required)
    //   - userAnswers: list (required)
    //   - totalQuestions: number (required)
    //   - lastUpdated: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (request.auth.token.email == "mechail.sbeatan1@gmail.com" ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt', 'lastLogin']) &&
             data.uid == request.auth.uid &&
             data.email == request.auth.token.email &&
             data.role in ['student', 'admin'] &&
             data.createdAt is timestamp &&
             data.lastLogin is timestamp;
    }

    function isValidAttempt(data) {
      return data.keys().hasAll(['subjectId', 'score', 'totalQuestions', 'markFrom40', 'isPassed', 'timestamp']) &&
             data.score is number &&
             data.totalQuestions is number &&
             data.markFrom40 is number &&
             data.isPassed is bool &&
             data.timestamp is timestamp;
    }

    function isValidProgress(data) {
      return data.keys().hasAll(['lastUpdated']) &&
             data.lastUpdated is timestamp;
    }

    function isValidQuizProgress(data) {
      return data.keys().hasAll(['subjectId', 'examTitle', 'currentQuestionIndex', 'userAnswers', 'totalQuestions', 'lastUpdated']) &&
             data.subjectId is string &&
             data.examTitle is string &&
             data.currentQuestionIndex is number &&
             data.userAnswers is list &&
             data.totalQuestions is number &&
             data.lastUpdated is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role == 'student' || isAdmin());
      allow update: if isOwner(uid) && (request.resource.data.role == resource.data.role || isAdmin());

      match /attempts/{attemptId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create: if isOwner(uid) && isValidAttempt(request.resource.data);
      }

      match /progress/current {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) && isValidProgress(request.resource.data);
      }

      match /quizProgress/{examTitle} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid) && isValidQuizProgress(request.resource.data);
        allow delete: if isOwner(uid);
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
